rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function publicLicenseUpdate() {
      return resource.data.status in ['unused', 'active']
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'activatedAt', 'deviceId', 'lastCheckedAt'])
        && request.resource.data.status in ['active', 'expired']
        && request.resource.data.deviceId is string
        && request.resource.data.lastCheckedAt is string;
    }

    match /admins/{adminId} {
      allow read: if signedIn() && request.auth.uid == adminId;
      allow write: if false;
    }

    match /licenses/{licenseId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || publicLicenseUpdate();
    }

    match /activationCodes/{code} {
      allow get: if true;
      allow list: if false;
      allow create, delete: if false;
      allow update: if signedIn()
        && resource.data.usedBy == null
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['usedBy', 'usedByEmail', 'usedAt'])
        && request.resource.data.usedBy == request.auth.uid
        && request.resource.data.usedByEmail == request.auth.token.email;
    }

    match /users/{userId} {
      allow create: if ownsUserDoc(userId);
      allow read, update, delete: if ownsUserDoc(userId);

      match /{collectionName}/{document} {
        allow read, write: if ownsUserDoc(userId) && collectionName != 'audit_logs';
      }

      match /audit_logs/{document} {
        allow read, create: if ownsUserDoc(userId);
        allow update, delete: if false;
      }
    }
  }
}
